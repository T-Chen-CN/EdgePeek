<UserControl x:Class="EdgePeek.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource WindowBg}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="18">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <TextBlock x:Name="TitleText"
                 Grid.Row="0"
                 Text="Settings"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextMain}"
                 Margin="0,0,0,14"/>

      <Border Grid.Row="1"
              Background="{StaticResource SurfaceBg}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,0,0,12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="138"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock x:Name="LanguageLabel" Grid.Row="0" Grid.Column="0" Text="Language" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,12"/>
          <ComboBox x:Name="LanguageBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12" SelectionChanged="LanguageBox_SelectionChanged">
            <ComboBoxItem Content="English" Tag="en"/>
            <ComboBoxItem Content="中文" Tag="zh-CN"/>
          </ComboBox>

          <TextBlock x:Name="HomeUrlLabel" Grid.Row="1" Grid.Column="0" Text="Home URL" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBox x:Name="HomeUrlBox" Grid.Row="1" Grid.Column="1"/>
        </Grid>
      </Border>

      <Border Grid.Row="2"
              Background="{StaticResource SurfaceBg}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,0,0,12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="138"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,12" VerticalAlignment="Center">
            <TextBlock x:Name="TriggerLabel" Text="Hot zone px" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
            <Button x:Name="TriggerHelpButton"
                    Content="?"
                    Width="22"
                    Height="22"
                    MinHeight="22"
                    Margin="7,0,0,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    ToolTipService.InitialShowDelay="120"
                    ToolTipService.ShowDuration="12000"
                    Click="TriggerHelpButton_Click"
                    ToolTip="Width of the screen-edge sensing area. Larger values are easier to trigger but may cause accidental popups."/>
          </StackPanel>
          <TextBox x:Name="TriggerBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"/>

          <TextBlock x:Name="HoverDelayLabel" Grid.Row="1" Grid.Column="0" Text="Edge delay ms" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,0"/>
          <TextBox x:Name="HoverDelayBox" Grid.Row="1" Grid.Column="1"/>
        </Grid>
      </Border>

      <Border Grid.Row="3"
              Background="{StaticResource SurfaceBg}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,0,0,14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="138"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock x:Name="HotkeyLabel" Grid.Row="0" Grid.Column="0" Text="Hotkey" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,12"/>
          <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
            <Button x:Name="RecordHotkeyButton" DockPanel.Dock="Right" Width="88" Content="Record" Click="RecordHotkeyButton_Click"/>
            <TextBox x:Name="HotkeyGestureBox" IsReadOnly="True" Margin="0,0,8,0"/>
          </DockPanel>

          <CheckBox x:Name="TopMostBox" Grid.Row="1" Grid.Column="1" Content="Keep panel above other windows" Margin="0,0,0,10"/>
          <CheckBox x:Name="HideOnLostFocusBox" Grid.Row="2" Grid.Column="1" Content="Hide when focus is lost" Margin="0,0,0,10"/>
          <CheckBox x:Name="StartWithWindowsBox" Grid.Row="3" Grid.Column="1" Content="Start with Windows" Margin="0,0,0,10"/>
          <CheckBox x:Name="ShowOnStartupBox" Grid.Row="4" Grid.Column="1" Content="Show panel when EdgePeek starts" Margin="0,0,0,10"/>
          <CheckBox x:Name="HotkeyBox" Grid.Row="5" Grid.Column="1" Content="Enable hotkey"/>
        </Grid>
      </Border>

      <Border Grid.Row="4"
              Background="{StaticResource SurfaceBg}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,0,0,14">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="138"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <TextBlock x:Name="DownloadFolderLabel" Grid.Row="0" Grid.Column="0" Text="Download folder" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,12"/>
          <DockPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
            <Button x:Name="BrowseDownloadFolderButton" DockPanel.Dock="Right" Width="76" Content="Browse" Click="BrowseDownloadFolderButton_Click"/>
            <TextBox x:Name="DownloadFolderBox" Margin="0,0,8,0"/>
          </DockPanel>

          <CheckBox x:Name="AskDownloadFolderBox" Grid.Row="1" Grid.Column="1" Content="Ask where to save each download"/>
        </Grid>
      </Border>

      <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="BackButton" Content="Back" Width="88" Margin="0,0,8,0" Click="BackButton_Click"/>
        <Button x:Name="SaveButton"
                Content="Save"
                Width="88"
                Background="{StaticResource AccentBrush}"
                Foreground="White"
                BorderBrush="{StaticResource AccentBrush}"
                Click="SaveButton_Click"/>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
