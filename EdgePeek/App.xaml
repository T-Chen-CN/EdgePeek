<Application x:Class="EdgePeek.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
    <SolidColorBrush x:Key="WindowBg" Color="#252B33"/>
    <SolidColorBrush x:Key="ChromeBg" Color="#2F3741"/>
    <SolidColorBrush x:Key="RailBg" Color="#2B333D"/>
    <SolidColorBrush x:Key="SurfaceBg" Color="#39424D"/>
    <SolidColorBrush x:Key="SurfaceSoft" Color="#353E49"/>
    <SolidColorBrush x:Key="BorderSoft" Color="#3E4A57"/>
    <SolidColorBrush x:Key="BorderStrong" Color="#5A6A7C"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#8AB4F8"/>
    <SolidColorBrush x:Key="AccentSoft" Color="#3C4D65"/>
    <SolidColorBrush x:Key="TextMain" Color="#EDF2F7"/>
    <SolidColorBrush x:Key="TextMuted" Color="#A7B2C0"/>

    <Style TargetType="{x:Type Button}">
      <Setter Property="MinHeight" Value="26"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Root"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="5">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#3B4652"/>
                <Setter TargetName="Root" Property="BorderBrush" Value="#4B5968"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Property="Background" Value="#44505E"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="{x:Type TextBox}">
      <Setter Property="MinHeight" Value="28"/>
      <Setter Property="Padding" Value="8,3"/>
      <Setter Property="Background" Value="#20262E"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <Style TargetType="{x:Type ScrollViewer}">
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <Style TargetType="{x:Type ItemsControl}">
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    </Style>

    <Style TargetType="{x:Type ComboBox}">
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="Padding" Value="6,3"/>
    </Style>

    <Style TargetType="{x:Type CheckBox}">
      <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
    </Style>
  </Application.Resources>
</Application>
