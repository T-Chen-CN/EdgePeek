<Window x:Class="EdgePeek.DownloadsPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Downloads"
        Width="360"
        SizeToContent="Height"
        MaxHeight="430"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Background="Transparent"
        AllowsTransparency="True">
  <Border Background="{StaticResource SurfaceBg}"
          BorderBrush="{StaticResource BorderStrong}"
          BorderThickness="1"
          CornerRadius="8"
          Padding="0">
    <Border.Effect>
      <DropShadowEffect BlurRadius="18"
                        ShadowDepth="4"
                        Direction="270"
                        Opacity="0.28"
                        Color="#000000"/>
    </Border.Effect>
    <DockPanel>
      <Grid DockPanel.Dock="Top" Height="42" Margin="12,6,8,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="30"/>
          <ColumnDefinition Width="30"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Downloads"
                   Foreground="{StaticResource TextMain}"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1" Click="ClearDownloadsButton_Click" ToolTip="Clear completed downloads">
          <TextBlock Text="&#xE74D;" FontFamily="{StaticResource IconFont}" FontSize="13"/>
        </Button>
        <Button Grid.Column="2" Click="CloseDownloadsButton_Click" ToolTip="Close">
          <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="13"/>
        </Button>
      </Grid>
      <ScrollViewer VerticalScrollBarVisibility="Auto"
                    MaxHeight="380"
                    Padding="0,0,0,4">
        <ItemsControl x:Name="DownloadsList" Margin="10,0,10,8"/>
      </ScrollViewer>
    </DockPanel>
  </Border>
</Window>
