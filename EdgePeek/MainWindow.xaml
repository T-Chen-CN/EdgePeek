<Window x:Class="EdgePeek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="EdgePeek"
        Width="460"
        Height="720"
        MinWidth="320"
        MinHeight="420"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Background="{StaticResource WindowBg}">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="0"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="6"
                        UseAeroCaptionButtons="False"/>
  </shell:WindowChrome.WindowChrome>
  <Border Background="{StaticResource WindowBg}"
          BorderBrush="{StaticResource BorderSoft}"
          BorderThickness="0"
          CornerRadius="10"
          ClipToBounds="True">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="LeftTabColumn" Width="52"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition x:Name="RightTabColumn" Width="0"/>
      </Grid.ColumnDefinitions>

      <Border x:Name="LeftTabRail"
              Grid.Column="0"
              Background="{StaticResource RailBg}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="0,0,1,0">
        <DockPanel LastChildFill="True" Margin="4">
          <Border DockPanel.Dock="Top"
                  Height="28"
                  Margin="0,0,0,6"
                  Background="Transparent"
                  BorderThickness="0"
                  CornerRadius="5"
                  ToolTip="Drag panel"
                  MouseLeftButtonDown="TabRail_MouseLeftButtonDown"
                  MouseMove="TabRail_MouseMove"
                  MouseLeftButtonUp="TabRail_MouseLeftButtonUp">
            <TextBlock Text="&#xE784;"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource IconFont}"
                       FontSize="14"
                       Foreground="{StaticResource TextMuted}"
                       FontWeight="Normal"/>
          </Border>
          <Button DockPanel.Dock="Bottom" Height="40" Click="NewTabButton_Click" ToolTip="New tab">
            <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="17"/>
          </Button>
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="LeftTabStrip"/>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="6"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="6"/>
        </Grid.RowDefinitions>

        <Border x:Name="TopResizeGrip"
                Grid.Row="0"
                Background="{StaticResource ChromeBg}"
                Cursor="SizeNS"
                MouseLeftButtonDown="TopResizeGrip_MouseLeftButtonDown"/>
        <Border x:Name="TopBar"
                Grid.Row="1"
                Height="38"
                ClipToBounds="True"
                Background="{StaticResource ChromeBg}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="0,0,0,1">
          <Grid Margin="6,5">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="30"/>
              <ColumnDefinition Width="30"/>
              <ColumnDefinition Width="30"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="30"/>
              <ColumnDefinition Width="30"/>
              <ColumnDefinition Width="30"/>
              <ColumnDefinition Width="30"/>
              <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton" Grid.Column="0" Click="BackButton_Click" ToolTip="Back">
              <TextBlock Text="&#xE72B;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMuted}"/>
            </Button>
            <Button x:Name="ForwardButton" Grid.Column="1" Click="ForwardButton_Click" ToolTip="Forward">
              <TextBlock Text="&#xE72A;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMuted}"/>
            </Button>
            <Button x:Name="RefreshButton" Grid.Column="2" Click="RefreshButton_Click" ToolTip="Refresh">
              <TextBlock Text="&#xE72C;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMain}"/>
            </Button>
            <TextBox x:Name="AddressBox"
                     Grid.Column="3"
                     Margin="4,0"
                     MinWidth="140"
                     VerticalContentAlignment="Center"
                     KeyDown="AddressBox_KeyDown"/>
            <Button x:Name="DownloadsButton" Grid.Column="4" Click="DownloadsButton_Click" ToolTip="Downloads">
              <TextBlock x:Name="DownloadsIcon" Text="&#xE896;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMain}"/>
            </Button>
            <Button x:Name="ViewModeButton" Grid.Column="5" Click="ViewModeButton_Click" ToolTip="Desktop mode">
              <TextBlock x:Name="ViewModeIcon" Text="&#xE977;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMain}"/>
            </Button>
            <Button Grid.Column="6" Click="HomeButton_Click" ToolTip="Home">
              <TextBlock Text="&#xE80F;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMain}"/>
            </Button>
            <Button Grid.Column="7" Click="SettingsButton_Click" ToolTip="Settings">
              <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMain}"/>
            </Button>
            <Button Grid.Column="8" Click="HideButton_Click" ToolTip="Hide panel">
              <TextBlock Text="&#xE711;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource TextMain}"/>
            </Button>
          </Grid>
        </Border>

        <Grid x:Name="BrowserHost" Grid.Row="2"/>
        <Grid x:Name="SettingsHost" Grid.Row="2" Visibility="Collapsed"/>
        <Border x:Name="BottomResizeGrip"
                Grid.Row="3"
                Background="{StaticResource WindowBg}"
                Cursor="SizeNS"
                MouseLeftButtonDown="BottomResizeGrip_MouseLeftButtonDown"/>
        <Border x:Name="UnsavedSettingsPrompt"
                Grid.Row="2"
                Background="{StaticResource SurfaceBg}"
                BorderBrush="{StaticResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="14"
                VerticalAlignment="Bottom"
                Visibility="Collapsed">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="UnsavedSettingsText"
                       Grid.Row="0"
                       Text="Settings have unsaved changes."
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
              <Button x:Name="UnsavedCancelButton" Content="Cancel" Width="76" Margin="0,0,8,0" Click="UnsavedCancelButton_Click"/>
              <Button x:Name="UnsavedDiscardButton" Content="Discard" Width="76" Margin="0,0,8,0" Click="UnsavedDiscardButton_Click"/>
              <Button x:Name="UnsavedSaveButton" Content="Save" Width="76" Click="UnsavedSaveButton_Click"/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <Border x:Name="RightTabRail"
              Grid.Column="2"
              Background="{StaticResource RailBg}"
              BorderBrush="{StaticResource BorderSoft}"
              BorderThickness="1,0,0,0"
              Visibility="Collapsed">
        <DockPanel LastChildFill="True" Margin="4">
          <Border DockPanel.Dock="Top"
                  Height="28"
                  Margin="0,0,0,6"
                  Background="Transparent"
                  BorderThickness="0"
                  CornerRadius="5"
                  ToolTip="Drag panel"
                  MouseLeftButtonDown="TabRail_MouseLeftButtonDown"
                  MouseMove="TabRail_MouseMove"
                  MouseLeftButtonUp="TabRail_MouseLeftButtonUp">
            <TextBlock Text="&#xE784;"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontFamily="{StaticResource IconFont}"
                       FontSize="14"
                       Foreground="{StaticResource TextMuted}"
                       FontWeight="Normal"/>
          </Border>
          <Button DockPanel.Dock="Bottom" Height="40" Click="NewTabButton_Click" ToolTip="New tab">
            <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="17"/>
          </Button>
          <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="RightTabStrip"/>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>
  </Border>
</Window>
